{
  "name": "office-design-tokens",
  "version": "1.1.1",
  "description": "办公设计规范 - 包含 tokens、markdown 样式和 AI 格式提示词",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "styles/",
    "scripts/",
    "package.json"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./markdown.css": "./dist/markdown.css",
    "./prompt": "./dist/ai-format-prompt.md",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "mkdir -p dist && cp styles/tokens.css dist/ && cp styles/markdown.css dist/ && cp styles/ai-format-prompt.md dist/ && node scripts/build-entry.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "design-tokens",
    "css",
    "markdown",
    "ai-prompt"
  ],
  "author": "办公设计团队",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourname/office-design-tokens.git"
  }
}
